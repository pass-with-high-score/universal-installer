    <string name="install_error_cancelled_title">इंस्टॉलेशन रद्द हो गया</string>
    <string name="install_error_cancelled_guidance">इंस्टॉलेशन को उपयोगकर्ता या सिस्टम द्वारा रद्द कर दिया गया था। पुनः प्रयास करने के लिए \'पुनः प्रयास करें\' पर टैप करें।</string>
    <string name="install_error_blocked_title">इंस्टॉलेशन ब्लॉक हो गया</string>
    <string name="install_error_blocked_guidance">आपकी डिवाइस नीति या सुरक्षा सेटिंग्स ने इस इंस्टॉल को ब्लॉक कर दिया है। जांचें कि सेटिंग्स &gt; ऐप्स &gt; विशेष एक्सेस में अज्ञात स्रोतों की अनुमति है या नहीं।</string>
    <string name="install_error_conflict_title">पैकेज में विरोध</string>
    <string name="install_error_conflict_guidance">विरोध करने वाला वर्ज़न पहले से ही इंस्टॉल है। पहले मौजूदा ऐप को अनइंस्टॉल करें, या Shizuku विकल्पों में \"मौजूदा को बदलें\" सक्षम करें।</string>
    <string name="install_error_incompatible_title">असंगत पैकेज</string>
    <string name="install_error_incompatible_guidance">यह APK आपके डिवाइस के अनुकूल नहीं है। इसे एक अलग CPU आर्किटेक्चर, Android वर्ज़न, या अनुपलब्ध हार्डवेयर सुविधा की आवश्यकता हो सकती है।</string>
    <string name="install_error_invalid_title">अमान्य पैकेज</string>
    <string name="install_error_invalid_guidance">APK फ़ाइल दूषित है या मान्य Android पैकेज नहीं है। इसे किसी विश्वसनीय स्रोत से फिर से डाउनलोड करने का प्रयास करें।</string>
    <string name="install_error_storage_title">पर्याप्त स्टोरेज नहीं है</string>
    <string name="install_error_storage_guidance">आपके डिवाइस में पर्याप्त खाली स्थान नहीं है। सेटिंग्स &gt; स्टोरेज में स्थान खाली करें और पुनः प्रयास करें।</string>
    <string name="install_error_timeout_title">इंस्टॉलेशन का समय समाप्त</string>
    <string name="install_error_timeout_guidance">इंस्टॉलेशन में बहुत अधिक समय लगा और उसे रद्द कर दिया गया। पुनः प्रयास करने के लिए \'पुनः प्रयास करें\' पर टैप करें।</string>
