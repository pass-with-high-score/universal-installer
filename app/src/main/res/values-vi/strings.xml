    <string name="install_error_cancelled_title">Đã hủy cài đặt</string>
    <string name="install_error_cancelled_guidance">Quá trình cài đặt đã bị người dùng hoặc hệ thống hủy. Nhấn Thử lại để thử lại.</string>
    <string name="install_error_blocked_title">Cài đặt bị chặn</string>
    <string name="install_error_blocked_guidance">Chính sách thiết bị hoặc cài đặt bảo mật của bạn đã chặn bản cài đặt này. Hãy kiểm tra xem các nguồn không xác định có được cho phép trong Cài đặt &gt; Ứng dụng &gt; Quyền truy cập đặc biệt hay không.</string>
    <string name="install_error_conflict_title">Xung đột gói</string>
    <string name="install_error_conflict_guidance">Một phiên bản xung đột đã được cài đặt. Trước tiên, hãy gỡ cài đặt ứng dụng hiện có hoặc bật \"Thay thế bản hiện tại\" trong các tùy chọn Shizuku.</string>
    <string name="install_error_incompatible_title">Gói không tương thích</string>
    <string name="install_error_incompatible_guidance">APK này không tương thích với thiết bị của bạn. Nó có thể yêu cầu một kiến trúc CPU khác, phiên bản Android khác hoặc thiếu tính năng phần cứng.</string>
    <string name="install_error_invalid_title">Gói không hợp lệ</string>
    <string name="install_error_invalid_guidance">Tệp APK bị hỏng hoặc không phải là gói Android hợp lệ. Hãy thử tải xuống lại từ một nguồn đáng tin cậy.</string>
    <string name="install_error_storage_title">Không đủ dung lượng lưu trữ</string>
    <string name="install_error_storage_guidance">Thiết bị của bạn không có đủ dung lượng trống. Hãy giải phóng dung lượng trong Cài đặt &gt; Bộ nhớ và thử lại.</string>
    <string name="install_error_timeout_title">Hết thời gian cài đặt</string>
    <string name="install_error_timeout_guidance">Quá trình cài đặt mất quá nhiều thời gian và đã bị hủy. Nhấn Thử lại để thử lại.</string>
    <string name="install_error_unexpected_title">Lỗi không mong muốn</string>
    <string name="install_error_unexpected_guidance">Đã xảy ra lỗi không mong muốn: %s. Hãy thử khởi động lại ứng dụng hoặc thiết bị của bạn.</string>
